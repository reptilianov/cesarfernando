---
import { useTranslations } from '../i18n/utils';

interface Props {
  locale: string;
}

const { locale } = Astro.props;
const { t } = useTranslations(locale);
---

<footer class="border-t border-[var(--color-border)] mt-10 py-10 px-4">
  <div class="max-w-[1000px] mx-auto grid grid-cols-1 md:grid-cols-3 gap-8 text-sm text-[var(--color-ink-muted)] font-body">

    <div>
      <p class="font-display text-[var(--color-ink)] font-semibold tracking-wide text-base">César Fernando</p>
      <p class="italic mt-1">{t('descripcion_sitio')}</p>
      <p class="mt-3">
        <a href="mailto:cefev.diseno@gmail.com" class="no-underline hover:text-[var(--color-amber)]">
          cefev.diseno@gmail.com
        </a>
      </p>
    </div>

    <div class="flex flex-col gap-2">
      <p class="font-display text-[var(--color-ink)] font-semibold tracking-wide">{t('secciones')}</p>
      <a href={`/${locale}/cuaderno/`} class="no-underline hover:text-[var(--color-amber)]">{t('cuaderno')}</a>
      <a href={`/${locale}/escritura/`} class="no-underline hover:text-[var(--color-amber)]">{t('escritura')}</a>
      <a href={`/${locale}/dibujos/`} class="no-underline hover:text-[var(--color-amber)]">{t('dibujos')}</a>
      <a href={`/${locale}/rasgunos/`} class="no-underline hover:text-[var(--color-amber)]">{t('rasgunos')}</a>
      <a href={`/${locale}/proceso/`} class="no-underline hover:text-[var(--color-amber)]">{t('proceso')}</a>
      <a href={`/${locale}/sobre/`} class="no-underline hover:text-[var(--color-amber)]">{t('sobre')}</a>
    </div>

    <div>
      <p class="font-display text-[var(--color-ink)] font-semibold tracking-wide mb-3">{t('suscribirse')}</p>
      <p class="mb-3 italic text-xs">Recibí mis apuntes, avances y dibujos directo en tu correo.</p>
      <script async src="https://eomail5.com/form/02dd09e4-68c7-11f1-9663-ed278820a0dd.js" data-form="02dd09e4-68c7-11f1-9663-ed278820a0dd"></script>
    </div>

  </div>
</footer>
